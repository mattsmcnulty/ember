{
  "_comment": "Copy to options.json and fill in. options.json is gitignored (holds the localKey).",
  "sauna": {
    "ip": "192.168.1.50",
    "devId": "YOUR_DEVICE_ID",
    "localKey": "YOUR_LOCAL_KEY",
    "version": 3.5
  },
  "sonos": {
    "name": "Sauna"
  },
  "apns": {
    "enabled": false,
    "keyId": "YOUR_APNS_KEY_ID",
    "teamId": "YOUR_APPLE_TEAM_ID",
    "p8Path": "/data/AuthKey.p8",
    "bundleId": "com.example.ember",
    "sandbox": true
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8765,
    "pollIntervalSec": 5,
    "apiKey": "CHANGE-ME-long-random-string (required Authorization: Bearer on /control etc; null disables auth)",
    "heaterMaxOnMinutes": null
  }
}
