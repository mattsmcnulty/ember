[Unit]
Description=emberd — Sun Home Eclipse 2 bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=/opt/emberd
Environment=EMBERD_OPTIONS=/opt/emberd/options.json
ExecStart=/opt/emberd/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 8765
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
