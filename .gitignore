# ── Phase-0 reverse-engineering scratch ──
# Kept on disk as a re-extraction safety net (see plan: Phase 0 Cleanup), never committed.
tools/phase0/

# ── Secrets — never commit ──
# (devices.json = Tuya localKey; options.json = runtime config w/ localKey; *.p8 = APNs key)
# NOTE: gitignore has no inline comments — keep patterns on their own lines.
**/devices.json
**/options.json
*.p8
.env
.env.*

# ── Python ──
.venv/
__pycache__/
*.pyc
*.pyo

# ── iOS / Xcode (ember/) ──
**/xcuserdata/
*.xcuserstate
DerivedData/
build/
*.ipa
*.dSYM/
.build/
Pods/
# xcodegen output — regenerate with `xcodegen generate` (source of truth = project.yml)
*.xcodeproj
ember/Info-App.plist
ember/Info-Widget.plist
ember/*.entitlements
# Personal build defaults (emberd URL + API key) — see Local.example.xcconfig
ember/Local.xcconfig

# ── Local tooling / machine-specific (never commit) ──
# Claude Code local settings/plans/memory — may hold machine-specific paths or creds.
.claude/

# ── Design source (large editable binaries; the exported PNGs are tracked, these are not) ──
*.psd
*.ai

# ── macOS ──
.DS_Store
